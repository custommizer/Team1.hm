"C:\\Users\\77051\\Desktop\\morrison-app\\src\\components\\layout\\Footer.jsx",[],"C:\\Users\\77051\\Desktop\\morrison-app\\src\\components\\footers\\Contacts.jsx",[],"C:\\Users\\77051\\Desktop\\morrison-app\\src\\components\\footers\\Socp.jsx",[],"C:\\Users\\77051\\Desktop\\morrison-app\\src\\components\\footers\\Pain.jsx",[],"C:\\Users\\77051\\Desktop\\morrison-app\\src\\components\\layout\\Navbar.jsx",["114","115"],"import React, { useState } from \"react\";\r\nimport searchIcon from \"./../../media/search-icon.png\";\r\nimport { Cards } from \"../data/Cards\";\r\nimport { Link } from \"react-router-dom\"\r\n\r\n\r\nfunction Navbar() {\r\n    const [sResults, setSResults] = useState(false)\r\n    const [search, setSearch] = useState(false)\r\n    const handleSearch = (sm) => {\r\n        setSearch(sm);\r\n        setSResults(\r\n            Cards.filter((elem) => elem.title.toLowerCase().includes(sm.toLowerCase())) \r\n        );    \r\n    };\r\n    return (\r\n        <nav className=\"navbar\">\r\n                <a href=\"\" className=\"navbar__logo\"></a>\r\n            <Link to=\"/\" className=\"navbar__link\">\r\n                Главная\r\n            </Link>\r\n            <Link to=\"/catalog\" className=\"navbar__link\">\r\n                Каталог\r\n            </Link>\r\n            <Link to=\"/korzina\" className=\"navbar__link\">\r\n                Избранные\r\n            </Link>\r\n            <Link to=\"/phones\" className=\"navbar__link\">\r\n                Смартфоны\r\n            </Link>\r\n            <Link to=\"/bicycles\" className=\"navbar__link\">\r\n                Велосипеды\r\n            </Link>\r\n            <div className=\"navbar__search\">\r\n                <input type=\"text\" placeholder=\"Я хочу найти...\" onChange={(e) => handleSearch(e.target.value)} />\r\n                <img src={searchIcon} alt=\"search\" />\r\n                {sResults && search.length > 0 ? (\r\n                    <ul className=\"smart__results\">\r\n                        {sResults.map((elem) => {\r\n                            return (\r\n                                <li key={\"searchId\" + elem.id}>\r\n                                    <Link to={\"/p/\" + elem.id}>{elem.title}</Link>\r\n                                </li>\r\n                            )\r\n                        })}\r\n                    </ul>\r\n                ) : null}\r\n            </div>\r\n        </nav>\r\n    )\r\n}\r\n\r\nexport default Navbar\r\n","C:\\Users\\77051\\Desktop\\morrison-app\\src\\components\\data\\Smart.jsx",[],"C:\\Users\\77051\\Desktop\\morrison-app\\src\\components\\data\\Cards.jsx",[],"C:\\Users\\77051\\Desktop\\morrison-app\\src\\components\\data\\Nout.jsx",[],"C:\\Users\\77051\\Desktop\\morrison-app\\src\\components\\data\\Bicy.jsx",[],"C:\\Users\\77051\\Desktop\\team10\\src\\index.jsx",[],["116","117"],"C:\\Users\\77051\\Desktop\\team10\\src\\App.jsx",[],"C:\\Users\\77051\\Desktop\\team10\\src\\header\\Header.jsx",["118","119"],"import { Link } from 'react-router-dom'\r\nimport \"./menu.css\"\r\nimport Menubar from './Menubar'\r\nimport React, {useState} from 'react'\r\nimport {AiOutlineMenuUnfold} from 'react-icons/ai'\r\nimport {FaCartArrowDown} from 'react-icons/fa'\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\nfunction Header() {\r\n    \r\n    const [show,setShow]=useState(false)\r\n    const [korz,setKorz]=useState(false)\r\n    \r\n   \r\n    return(\r\n        \r\n\r\n        <div className=\"header\">\r\n            <div className=\"header-inner\">\r\n            {\r\n                show?< Menubar setShow={setShow}/>:null\r\n            }\r\n            \r\n            <button  className=\"Header_buttons\" onClick={()=>setShow(true)}><AiOutlineMenuUnfold/></button>\r\n            <button className=\"Header_buttons\" onClick={()=>setKorz(true)}><FaCartArrowDown/></button>\r\n            \r\n           \r\n\r\n            </div>\r\n\r\n\r\n           \r\n        </div>      \r\n    )\r\n}\r\n\r\nexport default Header;","C:\\Users\\77051\\Desktop\\team10\\src\\mainpage\\Main.jsx",[],"C:\\Users\\77051\\Desktop\\team10\\src\\header\\Menubar.jsx",["120"],"import React, { useEffect } from 'react';\r\nimport { Link } from 'react-router-dom'\r\nimport { useState } from 'react'\r\nimport { FcHome } from 'react-icons/fc'\r\nimport { FcAbout } from 'react-icons/fc'\r\nimport { FcContacts } from 'react-icons/fc'\r\nimport { MdLocalGroceryStore } from 'react-icons/md'\r\nimport { IoIosCloseCircleOutline } from 'react-icons/io'\r\nimport { FcRules } from 'react-icons/fc'\r\nimport Aos from \"aos\";\r\nimport \"aos/dist/aos.css\";\r\nimport \"./menu.css\"\r\n\r\n\r\n\r\n\r\nfunction Menubar({ setShow }) {\r\n    useEffect(() => {\r\n        Aos.init({ duration: 250 });\r\n    }, []);\r\n\r\n\r\n    return (\r\n        <div className=\"menu\" data-aos=\"fade-right\" >\r\n            <div className=\"menu-inner\">\r\n\r\n                <div className=\"menu-list\">\r\n                    <button onClick={() => setShow(false)}><IoIosCloseCircleOutline /></button>\r\n\r\n                    <Link to=\"/main\" className=\"links_link\"> <FcHome /> Главная</Link>\r\n                    <Link to=\"/about-page\" className=\"links_link\"><FcAbout /> О нас  </Link>\r\n                    <Link to=\"/store\" className=\"links_link\"><MdLocalGroceryStore /> Магазин</Link>\r\n                    <Link to=\"/call\" className=\"links_link\"><FcContacts /> Контакты</Link>\r\n                    <Link to=\"/rule\" className=\"links_link\"><FcRules /> Условия заказа</Link>\r\n\r\n                </div>\r\n\r\n            </div>\r\n            <button className=\"ghostclose\" onClick={() => setShow(false)}></button>\r\n        </div>\r\n\r\n    )\r\n}\r\n\r\nexport default Menubar","C:\\Users\\77051\\Desktop\\team10\\src\\footer\\Footer.jsx",[],"C:\\Users\\77051\\Desktop\\team10\\src\\mainpage\\Summer\\Summer.jsx",[],"C:\\Users\\77051\\Desktop\\team10\\src\\mainpage\\About\\About.jsx",[],{"ruleId":"12