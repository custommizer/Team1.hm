ames":["React","Pain"],"mappings":";AAAA,OAAOA,KAAP,MAAkB,OAAlB;;;AAEA,SAASC,IAAT,GAAgB;AACZ,sBACI;AAAK,IAAA,SAAS,MAAd;AAAA,2BACI;AAAK,MAAA,SAAS,EAAC,MAAf;AAAA,8BACI;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,cADJ,eAEI;AAAK,QAAA,SAAS,EAAC,WAAf;AAAA,gCACI;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,gBADJ,eAEI;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,gBAFJ,eAGI;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,gBAHJ,eAII;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,gBAJJ,eAKA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,gBALA,eAMA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,gBANA,eAOA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,gBAPA,eAQA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,gBARA,eASA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,gBATA,eAUA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,gBAVA,eAWA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,gBAXA,eAYA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,gBAZA,eAaA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,gBAbA,eAcA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,gBAdA;AAAA;AAAA;AAAA;AAAA;AAAA,cAFJ;AAAA;AAAA;AAAA;AAAA;AAAA;AADJ;AAAA;AAAA;AAAA;AAAA,UADJ;AAuBH;;KAxBQA,I;AA0BT,eAAeA,IAAf","sourcesContent":["import React from 'react'\r\n\r\nfunction Pain() {\r\n    return (\r\n        <div className>\r\n            <div className=\"pain\">\r\n                <h1>Как сделать заказ</h1>\r\n                <div className=\"pain-text\">\r\n                    <h3>Шаг первый</h3>\r\n                    <p>В начале необходимо выбрать город, в котором будет осуществлена доставка. (Ассортимент товара и условия приобретения могут отличатся).</p>\r\n                    <h3>Шаг второй. Выбор товара</h3>\r\n                    <p>На сайте «Технодом» существует несколько способов поиска и выбора товара. Если Вы уже знаете, какую модель хотите купить — введите ее название в окно поиска в левом верхнем углу сайта. Если же с конкретной моделью Вы еще не определились, воспользуйтесь нашим каталогом, сервисом сравнения товаров и подбора по параметрам. Кроме того, в выборе товара Вам могут помочь опытные консультанты нашего интернет-магазина, звоните и задавайте вопросы по телефону 1717.</p>\r\n                <h3>Шаг третий. Оформление заказа</h3>\r\n                <p>Выбрав понравившийся вам товар, нажмите кнопку «КУПИТЬ», и товар автоматически отправится в вашу корзину. Обратите внимание, что товары, не имеющие этой кнопки, купить в интернет-магазине нельзя, они есть только в магазинах сети. Далее Вы можете продолжить выбор товаров в интернет-магазине, добавляя в корзину столько товаров, сколько Вам необходимо. Если Вы закончили выбор товаров, приступайте к оформлению заказа.</p>\r\n                <h3>Шаг четвертый. Оплата товара</h3>\r\n                <p>Покупки в интернет-магазине «Технодом» вы можете оплатить при помощи наличного или безналичного расчета, в том числе пластиковыми картами: онлайн (прямо на сайте) или при получении товара.</p>\r\n                <h3>Шаг пятый.  Доставка и получение товара</h3>\r\n                <li>Товары общей стоимостью свыше 10 000 тенге, доставляются бесплатно.</li>\r\n                <li>При заказе на сумму менее 10 000 тг. стоимость доставки зависит от веса. Тарифы смотреть здесь.</li>\r\n                <li>При необходимости Вы можете забрать свой заказ самостоятельно.</li>\r\n                <li>При получении товара клиенту необходимо предъявить документ, удостоверяющий личность.</li>\r\n                <li>Доставка работает 7 дней в неделю.</li>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    )\r\n}\r\n\r\nexport default Pain\r\n"]},"metadata":{},"sourceType":"module"}